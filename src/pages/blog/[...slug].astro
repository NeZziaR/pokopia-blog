---
// src/pages/blog/[...slug].astro
// Template article individuel — style carnet de terrain Pokemon
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map(post => ({
    params: { slug: post.slug },
    props:  { post, allPosts: posts },
  }));
}

const { post, allPosts } = Astro.props;
const { Content } = await render(post);

// Articles liés : triés par nombre de tags communs, max 3
const currentTags = post.data.tags ?? [];
const related = allPosts
  .filter(p => p.slug !== post.slug)
  .map(p => {
    const sharedTags = (p.data.tags ?? []).filter(t => currentTags.includes(t)).length;
    return { post: p, sharedTags };
  })
  .sort((a, b) => b.sharedTags - a.sharedTags)
  .slice(0, 3)
  .map(r => r.post);

const formatDate = (date: Date) =>
  date.toLocaleDateString('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title={post.data.title} description={post.data.description}>

  <!-- Lien retour homepage -->
  <a
    href="/"
    class="inline-flex items-center gap-1 text-green-600 hover:text-green-700 font-semibold text-sm mb-8 no-underline transition-colors"
  >
    ← Tous les guides
  </a>

  <article class="prose prose-stone prose-base md:prose-lg max-w-none">

    <!-- ================================================================
         En-tête article — hors prose pour style custom
         ================================================================ -->
    <header class="not-prose mb-10">

      <!-- Tags style badge Type Pokemon -->
      {post.data.tags && post.data.tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-5">
          {post.data.tags.map(tag => (
            <span class="inline-flex items-center gap-1 border-2 border-green-300 bg-green-50 text-green-700 rounded-full px-3 py-0.5 text-xs font-bold uppercase tracking-wide">
              ✦ {tag}
            </span>
          ))}
        </div>
      )}

      <!-- Titre H1 -->
      <h1 class="font-display text-3xl md:text-4xl font-bold text-stone-800 leading-tight mb-3">
        {post.data.title}
      </h1>

      <!-- Date -->
      <time datetime={post.data.pubDate.toISOString()} class="text-stone-400 text-sm">
        Publié le {formatDate(post.data.pubDate)}
      </time>

      <!-- Séparateur herbe style AC -->
      <div class="flex items-center gap-1 mt-5 mb-8" aria-hidden="true">
        <div class="h-1 flex-1 rounded-full bg-gradient-to-r from-green-300 via-green-200 to-transparent"></div>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="text-green-400 shrink-0">
          <path d="M17 8C8 10 5.9 16.17 3.82 19.85a1 1 0 1 0 1.75.98C7.01 17.56 8.74 13 17 12"/>
          <path d="M3 3a19.74 19.74 0 0 1 14 7A19.93 19.93 0 0 1 20 21c-3.5-2-6-5-6-10A10 10 0 0 0 3 3"/>
        </svg>
        <div class="h-1 flex-1 rounded-full bg-gradient-to-l from-green-300 via-green-200 to-transparent"></div>
      </div>

      <!-- Image héro optionnelle -->
      {post.data.heroImage && (
        <img
          src={post.data.heroImage}
          alt={post.data.title}
          class="w-full rounded-2xl shadow-sm object-cover aspect-video"
          loading="eager"
        />
      )}

    </header>

    <!-- Corps MDX -->
    <Content />

  </article>

  <!-- ================================================================
       Articles liés — "Lire aussi"
       ================================================================ -->
  {related.length > 0 && (
    <aside class="not-prose mt-16 pt-10 border-t border-amber-100">

      <!-- Titre section -->
      <h2 class="font-display text-xl font-bold text-stone-700 mb-6 flex items-center gap-2">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" class="text-green-400" aria-hidden="true">
          <path d="M17 8C8 10 5.9 16.17 3.82 19.85a1 1 0 1 0 1.75.98C7.01 17.56 8.74 13 17 12"/>
          <path d="M3 3a19.74 19.74 0 0 1 14 7A19.93 19.93 0 0 1 20 21c-3.5-2-6-5-6-10A10 10 0 0 0 3 3"/>
        </svg>
        Lire aussi
      </h2>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {related.map(p => (
          <a
            href={`/blog/${p.slug}`}
            class="group bg-white border border-amber-100 rounded-3xl shadow-sm p-5 hover:border-green-200 hover:shadow-md transition-all flex flex-col gap-3 no-underline"
          >
            <!-- Barre HP -->
            <div class="flex items-center gap-1" aria-hidden="true">
              <div class="h-1.5 w-8 rounded-full bg-green-400"></div>
              <div class="h-1.5 w-4 rounded-full bg-green-200"></div>
              <div class="h-1.5 w-2 rounded-full bg-green-100"></div>
            </div>

            <!-- Tags -->
            {p.data.tags && p.data.tags.length > 0 && (
              <div class="flex flex-wrap gap-1.5">
                {p.data.tags.slice(0, 2).map(tag => (
                  <span class="border-2 border-green-300 bg-green-50 text-green-700 rounded-full px-2.5 py-0.5 text-xs font-bold uppercase tracking-wide">
                    ✦ {tag}
                  </span>
                ))}
              </div>
            )}

            <!-- Titre -->
            <p class="font-display font-bold text-stone-800 text-sm leading-snug group-hover:text-green-600 transition-colors">
              {p.data.title}
            </p>

            <!-- Description -->
            <p class="text-stone-400 text-xs leading-relaxed line-clamp-2 flex-1">
              {p.data.description}
            </p>

            <!-- Lire → -->
            <span class="text-green-600 text-xs font-bold mt-1">Lire l'article →</span>
          </a>
        ))}
      </div>

    </aside>
  )}

</BaseLayout>
