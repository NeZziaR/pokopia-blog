---
// src/pages/index.astro
// Page d'accueil : hero + grille de tous les articles publiés
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

// Récupération de tous les articles non-draft, triés par date décroissante
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort(
  (a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
);

// Formatage de la date en français
const formatDate = (date: Date) =>
  date.toLocaleDateString('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout
  title="Guides Pokopia"
  description="Tous les guides et astuces pour progresser dans Pokopia. Conseils débutants, stratégies avancées et secrets du jeu."
>

  <!-- ================================================================
       Section héro
       ================================================================ -->
  <section class="text-center py-14 mb-4">
    <h1 class="font-display text-4xl md:text-5xl font-bold text-slate-800 mb-4 leading-tight">
      Bienvenue sur Pokopia.blog 🌿
    </h1>
    <p class="text-slate-500 text-lg max-w-xl mx-auto leading-relaxed">
      Guides, astuces et secrets pour progresser dans Pokopia.
      Écrits avec passion par un vrai joueur.
    </p>
  </section>

  <!-- ================================================================
       Grille d'articles
       ================================================================ -->
  <section>
    <h2 class="font-display text-2xl font-bold text-slate-700 mb-6">
      Derniers guides
    </h2>

    {posts.length === 0 ? (
      <p class="text-slate-400 text-center py-16">
        Aucun article pour l'instant — revenez bientôt !
      </p>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {posts.map(post => (
          <article class="bg-white rounded-3xl shadow-sm p-6 hover:shadow-md transition-shadow flex flex-col gap-4">

            <!-- Tags -->
            {post.data.tags && post.data.tags.length > 0 && (
              <div class="flex flex-wrap gap-2">
                {post.data.tags.map(tag => (
                  <span class="bg-sky-100 text-sky-600 rounded-full px-3 py-1 text-xs font-semibold">
                    {tag}
                  </span>
                ))}
              </div>
            )}

            <!-- Titre lié à l'article -->
            <h3 class="font-display text-lg font-bold text-slate-800 leading-snug">
              <a
                href={`/blog/${post.slug}`}
                class="hover:text-sky-500 transition-colors no-underline"
              >
                {post.data.title}
              </a>
            </h3>

            <!-- Description tronquée -->
            <p class="text-slate-500 text-sm line-clamp-3 flex-1 leading-relaxed">
              {post.data.description}
            </p>

            <!-- Date de publication -->
            <time
              datetime={post.data.pubDate.toISOString()}
              class="text-slate-400 text-xs"
            >
              {formatDate(post.data.pubDate)}
            </time>

          </article>
        ))}
      </div>
    )}
  </section>

</BaseLayout>
