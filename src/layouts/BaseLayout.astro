---
// src/layouts/BaseLayout.astro
// Shell HTML — Header cozy nature + Footer avec mention affilié
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Pokopia.blog</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Quicksand:wght@600;700&family=Nunito:wght@400;600&display=swap"
      rel="stylesheet"
    />
  </head>

  <body class="min-h-screen flex flex-col">

    <!-- ================================================================
         Header — glassmorphism chaud sur fond crème
         ================================================================ -->
    <header class="sticky top-0 z-50 bg-white/10 backdrop-blur-md border-b border-white/20">
      <nav class="max-w-4xl mx-auto px-6 py-3 flex items-center justify-between">

        <!-- Logo : feuille SVG + texte Quicksand vert -->
        <a href="/" class="flex items-center gap-2 no-underline group">
          <!-- Feuille Pokemon / fougère AC -->
          <svg
            width="22" height="22" viewBox="0 0 24 24" fill="currentColor"
            class="text-green-500 group-hover:text-green-600 transition-colors"
            aria-hidden="true"
          >
            <path d="M17 8C8 10 5.9 16.17 3.82 19.85a1 1 0 1 0 1.75.98C7.01 17.56 8.74 13 17 12"/>
            <path d="M3 3a19.74 19.74 0 0 1 14 7A19.93 19.93 0 0 1 20 21c-3.5-2-6-5-6-10A10 10 0 0 0 3 3"/>
          </svg>
          <span class="font-display text-xl font-bold text-green-600 group-hover:text-green-700 transition-colors">
            Pokopia.blog
          </span>
        </a>

        <!-- Navigation -->
        <a
          href="/"
          class="text-stone-600 hover:text-green-600 font-semibold text-sm transition-colors"
        >
          Guides
        </a>

      </nav>
    </header>

    <!-- ================================================================
         Slot hero — pleine largeur, hors du container centré.
         Utilisé uniquement par les pages qui fournissent <... slot="hero">
         ================================================================ -->
    <slot name="hero" />

    <!-- ================================================================
         Contenu principal — max-w-6xl centré
         ================================================================ -->
    <main class="flex-1 max-w-6xl mx-auto w-full px-6 py-10">
      <slot />
    </main>

    <!-- ================================================================
         Footer — fond doux avec étoiles décoratives
         ================================================================ -->
    <footer class="bg-green-50 border-t border-green-100 mt-auto">
      <div class="max-w-4xl mx-auto px-6 py-8 text-center">
        <!-- Petites étoiles décoratives style Pokemon -->
        <div class="flex justify-center gap-3 mb-3 text-green-300 text-sm select-none" aria-hidden="true">
          <span>✦</span><span>✦</span><span>✦</span>
        </div>
        <p class="text-stone-500 text-sm font-semibold mb-1">© 2025 Pokopia.blog</p>
        <p class="text-stone-400 text-xs max-w-lg mx-auto leading-relaxed">
          En tant que Partenaire Amazon, je réalise un bénéfice sur les achats remplissant les conditions requises.
        </p>
      </div>
    </footer>

  </body>
</html>
