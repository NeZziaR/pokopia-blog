---
// src/components/ProductCard.astro
// Fiche produit affilié Amazon — carte horizontale (desktop) / verticale (mobile)

interface Props {
  /** Nom du produit */
  title: string;
  /** Prix affiché (ex : "69,99 €") */
  price: string;
  /** Chemin vers l'image dans /public (ex : "/images/switch2.webp") */
  imageUrl: string;
  /** URL affilié Amazon */
  shopUrl: string;
  /** 2 à 3 points forts du produit */
  features: string[];
  /** Texte du badge (défaut : "Choix de la rédaction") */
  badge?: string;
  /** Texte du bouton (défaut : "Voir sur Amazon") */
  buttonLabel?: string;
}

const {
  title,
  price,
  imageUrl,
  shopUrl,
  features,
  badge = "Choix de la rédaction",
  buttonLabel = "Voir sur Amazon",
} = Astro.props;
---

<!-- not-prose : échappe les styles @tailwindcss/typography de l'article -->
<div class="not-prose my-8 rounded-2xl border border-stone-200 shadow-md overflow-hidden bg-white">

  <!-- Badge — bandeau supérieur coloré -->
  <div class="flex items-center gap-2 bg-amber-50 border-b border-amber-100 px-5 py-2">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" class="text-amber-500 shrink-0" aria-hidden="true">
      <polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26"/>
    </svg>
    <span class="text-xs font-bold text-amber-700 uppercase tracking-widest">{badge}</span>
  </div>

  <!-- Corps de la carte : flex-col mobile → flex-row desktop -->
  <div class="flex flex-col md:flex-row">

    <!-- Zone image — fond légèrement grisé, image centrée -->
    <div class="w-full md:w-52 shrink-0 bg-stone-50 flex items-center justify-center p-6 border-b md:border-b-0 md:border-r border-stone-100">
      <img
        src={imageUrl}
        alt={title}
        class="w-36 h-36 md:w-40 md:h-40 object-contain"
        loading="lazy"
      />
    </div>

    <!-- Zone contenu -->
    <div class="flex-1 p-5 flex flex-col gap-4">

      <!-- Titre + prix -->
      <div>
        <h3 class="font-display font-bold text-stone-800 text-lg leading-snug mb-2">
          {title}
        </h3>
        <p class="text-3xl font-bold text-green-600 leading-none">
          {price}
        </p>
      </div>

      <!-- Points forts avec icône coche verte -->
      <ul class="space-y-1.5">
        {features.map(feature => (
          <li class="flex items-start gap-2 text-sm text-stone-600">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-green-500 shrink-0 mt-0.5" aria-hidden="true">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            {feature}
          </li>
        ))}
      </ul>

      <!-- Bouton affilié Amazon — poussé en bas à droite -->
      <div class="mt-auto pt-2 flex justify-end">
        <a
          href={shopUrl}
          target="_blank"
          rel="nofollow noopener sponsored"
          class="inline-flex items-center gap-2 bg-[#FF9900] hover:bg-[#e68900] text-black font-bold rounded-full px-6 py-2.5 shadow-sm hover:scale-105 transition-transform duration-200 text-sm no-underline"
        >
          🛒 {buttonLabel}
        </a>
      </div>

    </div>
  </div>
</div>
