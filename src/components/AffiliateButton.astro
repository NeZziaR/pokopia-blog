---
// src/components/AffiliateButton.astro
// Bouton lien affilié Amazon — style officiel orange Amazon

interface Props {
  /** URL Amazon (avec tag affilié) */
  url: string;
  /** Texte affiché dans le bouton */
  label?: string;
}

const { url, label = "Voir sur Amazon" } = Astro.props;
---

<a
  href={url}
  target="_blank"
  rel="nofollow noopener sponsored"
  class="inline-flex items-center gap-2 bg-[#FF9900] hover:bg-[#e68900] text-black font-bold rounded-full px-6 py-3 shadow-md hover:scale-105 transition-transform duration-200 no-underline"
>
  🛒 {label}
</a>
