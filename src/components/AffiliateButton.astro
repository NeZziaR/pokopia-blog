---
// src/components/AffiliateButton.astro
// Bouton lien affilié Amazon — style cozy ambré

interface Props {
  /** URL Amazon (avec tag affilié) */
  href: string;
  /** Texte affiché dans le bouton */
  label?: string;
}

const { href, label = "Voir sur Amazon" } = Astro.props;
---

<a
  href={href}
  target="_blank"
  rel="nofollow noopener sponsored"
  class="inline-flex items-center gap-2 bg-amber-200 hover:bg-amber-300 text-slate-800 font-semibold rounded-2xl px-6 py-3 shadow-sm transition-colors no-underline"
>
  <!-- Icône panier (SVG inline 20×20) -->
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width="20"
    height="20"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
    focusable="false"
  >
    <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" />
    <line x1="3" y1="6" x2="21" y2="6" />
    <path d="M16 10a4 4 0 0 1-8 0" />
  </svg>

  {label}
</a>
